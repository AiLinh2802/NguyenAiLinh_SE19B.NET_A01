@using NguyenAiLinhMVC.ViewModels
@model IReadOnlyList<AccountFormViewModel>
@{
    ViewData["Title"] = "Account Management";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Account Management</h2>
    <div class="d-flex gap-2">
        <form method="get" class="d-flex gap-2">
            <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search account" />
            <button type="submit" class="btn btn-outline-primary">Search</button>
        </form>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createAccountModal">Create Account</button>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-bordered table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Created News</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.AccountId</td>
                <td>@item.AccountName</td>
                <td>@item.AccountEmail</td>
                <td>@item.RoleName</td>
                <td>@item.CreatedNewsCount</td>
                <td class="text-center">
                    <button class="btn btn-sm btn-warning" data-bs-toggle="modal" data-bs-target="#editAccount-@item.AccountId">Edit</button>
                    <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Delete this account?');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="accountId" value="@item.AccountId" />
                        <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

<div class="modal fade" id="createAccountModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header"><h5 class="modal-title">Create Account</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                <div class="modal-body">
                    <div class="mb-3"><label class="form-label">Name</label><input name="AccountName" class="form-control" required maxlength="100" /></div>
                    <div class="mb-3"><label class="form-label">Email</label><input name="AccountEmail" type="email" class="form-control" required maxlength="70" /></div>
                    <div class="mb-3">
                        <label class="form-label">Role</label>
                        <select name="AccountRole" class="form-select" required>
                            <option value="1">Staff</option>
                            <option value="2">Lecturer</option>
                        </select>
                    </div>
                    <div class="mb-3"><label class="form-label">Password</label><input name="AccountPassword" type="password" class="form-control" required minlength="6" maxlength="70" /></div>
                </div>
                <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button><button type="submit" class="btn btn-primary">Save</button></div>
            </form>
        </div>
    </div>
</div>

@foreach (var item in Model)
{
    <div class="modal fade" id="editAccount-@item.AccountId" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="AccountId" value="@item.AccountId" />
                    <div class="modal-header"><h5 class="modal-title">Edit Account</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                    <div class="modal-body">
                        <div class="mb-3"><label class="form-label">Name</label><input name="AccountName" class="form-control" value="@item.AccountName" required maxlength="100" /></div>
                        <div class="mb-3"><label class="form-label">Email</label><input name="AccountEmail" type="email" class="form-control" value="@item.AccountEmail" required maxlength="70" /></div>
                        <div class="mb-3">
                            <label class="form-label">Role</label>
                            <select name="AccountRole" class="form-select" required>
                                <option value="1" selected="@(item.AccountRole == 1)">Staff</option>
                                <option value="2" selected="@(item.AccountRole == 2)">Lecturer</option>
                            </select>
                        </div>
                        <div class="mb-3"><label class="form-label">New Password</label><input name="AccountPassword" type="password" class="form-control" required minlength="6" maxlength="70" /></div>
                    </div>
                    <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button><button type="submit" class="btn btn-primary">Update</button></div>
                </form>
            </div>
        </div>
    </div>
}
