@using NguyenAiLinhMVC.ViewModels
@using FUNewsManagement.BLL.Dtos
@model IReadOnlyList<NewsArticleFormViewModel>
@{
    ViewData["Title"] = "News Management";
    var categories = (IEnumerable<CategoryDto>)ViewBag.Categories;
    var tags = (IEnumerable<TagDto>)ViewBag.Tags;
    var nextNewsArticleId = (string)ViewBag.NextNewsArticleId;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">News Management</h2>
    <div class="d-flex gap-2">
        <form method="get" class="d-flex gap-2">
            <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search news" />
            <button type="submit" class="btn btn-outline-primary">Search</button>
        </form>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createNewsModal">Create News</button>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-bordered table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Category</th>
                <th>Status</th>
                <th>Created By</th>
                <th>Created Date</th>
                <th>Tags</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.NewsArticleId</td>
                    <td>@item.NewsTitle</td>
                    <td>@item.CategoryName</td>
                    <td>@(item.NewsStatus ? "Active" : "Inactive")</td>
                    <td>@item.CreatedByName</td>
                    <td>@item.CreatedDate?.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@(item.TagNames.Any() ? string.Join(", ", item.TagNames) : "None")</td>
                    <td class="text-center">
                        <button class="btn btn-sm btn-warning" data-bs-toggle="modal" data-bs-target="#editNews-@item.NewsArticleId">Edit</button>
                        <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Delete this news article?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="newsArticleId" value="@item.NewsArticleId" />
                            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                        </form>
                        <a class="btn btn-sm btn-outline-secondary" asp-controller="Home" asp-action="NewsDetails" asp-route-id="@item.NewsArticleId">View</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="modal fade" id="createNewsModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header"><h5 class="modal-title">Create News</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">ID</label>
                            <div class="form-control bg-light">New ID: @nextNewsArticleId</div>
                            <input type="hidden" name="NewsArticleId" value="@nextNewsArticleId" />
                        </div>
                        <div class="col-md-6"><label class="form-label">Category</label><select name="CategoryId" class="form-select" required><option value="">Select category</option>@foreach (var option in categories) {
                        <option value="@option.CategoryId">@option.CategoryName</option>
                                                }
</select></div>
                        <div class="col-12"><label class="form-label">Title</label><input name="NewsTitle" class="form-control" required maxlength="400" /></div>
                        <div class="col-12"><label class="form-label">Headline</label><input name="Headline" class="form-control" required maxlength="150" /></div>
                        <div class="col-md-6"><label class="form-label">Source</label><input name="NewsSource" class="form-control" required maxlength="400" /></div>
                        <div class="col-md-6"><label class="form-label">Tags</label><select name="TagIds" class="form-select" multiple size="5">@foreach (var option in tags) {
                        <option value="@option.TagId">@option.TagName</option>
                                                }
</select></div>
                        <div class="col-12"><label class="form-label">Content</label><textarea name="NewsContent" class="form-control" rows="5" required maxlength="4000"></textarea></div>
                        <div class="col-12 form-check ms-2"><input name="NewsStatus" value="true" type="checkbox" class="form-check-input" checked /><input name="NewsStatus" value="false" type="hidden" /><label class="form-check-label">Active</label></div>
                    </div>
                </div>
                <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button><button type="submit" class="btn btn-primary">Save</button></div>
            </form>
        </div>
    </div>
</div>

@foreach (var item in Model)
{
    <div class="modal fade" id="editNews-@item.NewsArticleId" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-header"><h5 class="modal-title">Edit News</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">ID</label>
                                <div class="form-control bg-light">@item.NewsArticleId</div>
                                <input type="hidden" name="NewsArticleId" value="@item.NewsArticleId" />
                            </div>
                            <div class="col-md-6"><label class="form-label">Category</label><select name="CategoryId" class="form-select" required>@foreach (var option in categories) {
                            <option value="@option.CategoryId" selected="@(option.CategoryId == item.CategoryId)">@option.CategoryName</option>
                        }
</select></div>
                        <div class="col-12"><label class="form-label">Title</label><input name="NewsTitle" class="form-control" value="@item.NewsTitle" required maxlength="400" /></div>
                        <div class="col-12"><label class="form-label">Headline</label><input name="Headline" class="form-control" value="@item.Headline" required maxlength="150" /></div>
                        <div class="col-md-6"><label class="form-label">Source</label><input name="NewsSource" class="form-control" value="@item.NewsSource" required maxlength="400" /></div>
                        <div class="col-md-6"><label class="form-label">Tags</label><select name="TagIds" class="form-select" multiple size="5">@foreach (var option in tags) {
                        <option value="@option.TagId" selected="@(item.TagIds.Contains(option.TagId))">@option.TagName</option>
                                                }
</select></div>
                        <div class="col-12"><label class="form-label">Content</label><textarea name="NewsContent" class="form-control" rows="5" required maxlength="4000">@item.NewsContent</textarea></div>
                        <div class="col-12 form-check ms-2"><input name="NewsStatus" value="true" type="checkbox" class="form-check-input" checked="@item.NewsStatus" /><input name="NewsStatus" value="false" type="hidden" /><label class="form-check-label">Active</label></div>
                    </div>
                </div>
                <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button><button type="submit" class="btn btn-primary">Update</button></div>
            </form>
        </div>
    </div>
</div>
}
