@using NguyenAiLinhMVC.ViewModels
@model IReadOnlyList<NewsArticleFormViewModel>
@{
    ViewData["Title"] = "My News History";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">My News History</h2>
    <form method="get" class="d-flex gap-2">
        <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search my news" />
        <button type="submit" class="btn btn-outline-primary">Search</button>
    </form>
</div>

<div class="table-responsive">
    <table class="table table-bordered table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Status</th>
                <th>Created Date</th>
                <th>Modified Date</th>
                <th>Tags</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.NewsArticleId</td>
                    <td>@item.NewsTitle</td>
                    <td>@(item.NewsStatus ? "Active" : "Inactive")</td>
                    <td>@item.CreatedDate?.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@item.ModifiedDate?.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@(item.TagNames.Any() ? string.Join(", ", item.TagNames) : "None")</td>
                </tr>
            }
        </tbody>
    </table>
</div>
